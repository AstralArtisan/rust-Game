      (MirrorWarden,  44.0),
      (TideHunter,    52.0),
      (CubeCore,      48.0),
    ],
  ),
  // MirrorWarden split sub-core HP: base + phase * per_phase.
  sub_core_base_hp: 40.0,
  sub_core_hp_per_phase: 10.0,
